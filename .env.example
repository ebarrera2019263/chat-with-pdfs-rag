# ---------------------------------------------------------------------------
# Copia este archivo a .env y rellena tus claves. NUNCA subas .env a git.
# ---------------------------------------------------------------------------

# --- Anthropic (LLM de respuestas) ---
# Consigue tu key gratis en https://console.anthropic.com  (Settings -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# --- Voyage AI (embeddings) ---
# Key gratis en https://dashboard.voyageai.com  (incluye tokens gratis)
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024

# --- Qdrant Cloud (vector DB) ---
# Crea un cluster gratis en https://cloud.qdrant.io
# Copia la URL del cluster (termina en :6333) y crea una API key.
QDRANT_URL=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=...
QDRANT_COLLECTION=pdf_chunks

# --- Ingesta / chunking ---
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
MAX_UPLOAD_MB=20

# --- Retrieval ---
TOP_K=5
MIN_SCORE=0.3
